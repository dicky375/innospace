# ─── APP SETTINGS ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=InnoSpace Connect

# ─── PORTS (Microservices) ─────────────────────────────────────
LOAD_BALANCER_PORT=3000
SERVER1_PORT=3001   # Auth Service
SERVER2_PORT=3002   # Registration Service
SERVER3_PORT=3003   # Payment Service

# ─── DATABASE CONFIG ───────────────────────────────────────────
# Auth Service Database
DB_AUTH_HOST=localhost
DB_AUTH_PORT=5432
DB_AUTH_NAME=innospace_auth
DB_AUTH_USER=postgres
DB_AUTH_PASS=dicky123

# Registration Service Database
DB_REG_HOST=localhost
DB_REG_PORT=5432
DB_REG_NAME=innospace_registrations
DB_REG_USER=postgres
DB_REG_PASS=dicky123

# Payment Service Database
DB_PAY_HOST=localhost
DB_PAY_PORT=5432
DB_PAY_NAME=innospace_payments
DB_PAY_USER=postgres
DB_PAY_PASS=dicky123

# ─── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://default:E14gAHZ7Z0V1zMXVzS6zSp2MdGSaomuD@redis-19746.c8.us-east-1-3.ec2.cloud.redislabs.com:19746

# ─── JWT AUTHENTICATION ────────────────────────────────────────
# IMPORTANT: Change these in production! Use strong random secrets.
JWT_ACCESS_SECRET=your-super-long-random-jwt-access-secret-here-please-change-this-in-production
JWT_REFRESH_SECRET=your-super-long-random-jwt-refresh-secret-here-please-change-this-in-production
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_EXPIRES=7d

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── PAYSTACK PAYMENT GATEWAY ──────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── BUSINESS LOGIC ────────────────────────────────────────────
COMMISSION_RATE=0.1

# ─── SECURITY HEADERS ──────────────────────────────────────────
# Optional but recommended
HELME_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes