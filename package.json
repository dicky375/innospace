{
  
  "name": "innospace",
  
  "version": "1.0.0",
  
  "description": "High-availability microservices architecture for tech hub reg",
  
  "type": "module",
  
  "main": "load-balancer/index.js",
  
  "scripts": {
  
    
  "kill-ports": "npx kill-port 3000 3001 3002 3003 || true",
  
    
  "start": "node load-balancer/index.js",
  
    
  "lb": "nodemon load-balancer/index.js",
  
    
  "s1:auth": "nodemon servers/server1-auth/index.js",
  
    
  "s2:reg": "nodemon servers/server2-registration/index.js",
  
    
  "s3:pay": "nodemon servers/server3-payment/index.js",
  
    
  "dev": "npm run kill-ports && concurrently -n \"LB,AUTH,REG,PAY\" -c \"magenta,blue,green,yellow\" \"npm run lb\" \"npm run s1:auth\" \"npm run s2:reg\" \"npm run s3:pay\"",
  
    
  "db:migrate": "npx sequelize-cli db:migrate",
  
    
  "db:rollback": "npx sequelize-cli db:migrate:undo"
  
  },
  
  "keywords": [
  
    
  "microservices",
  
    
  "load-balancer",
  
    
  "node-js",
  
    
  "redis",
  
    
  "express",
  
    
  "paystack"
  
  ],
  
  "author": "",
  
  "license": "ISC",
  
  "dependencies": {
  
    
  "axios": "^1.7.7",
  
    
  "bcryptjs": "^3.0.3",
  
    
  "cors": "^2.8.6",
  
    
  "dotenv": "^17.3.1",
  
    
  "express": "^5.2.1",
  
    
  "helmet": "^8.1.0",
  
    
  "http-proxy": "^1.18.1",
  
    
  "ioredis": "^5.10.0",
  
    
  "jsonwebtoken": "^9.0.3",
  
    
  "morgan": "^1.10.1",
  
    
  "multer": "^2.1.1",
  
    
  "pg": "^8.20.0",
  
    
  "pg-hstore": "^2.3.4",
  
    
  "sequelize": "^6.37.8"
  
  },
  
  "devDependencies": {
  
    
  "concurrently": "^8.2.2",
  
    
  "kill-port": "^2.0.1",
  
    
  "nodemon": "^3.1.14",
  
    
  "sequelize-cli": "^6.6.5"
  
  }
}
